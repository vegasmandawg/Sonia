{
  "name": "sonia:-your-ai-companion",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "node scripts/deploy-cli.js",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod --dir=dist",
    "deploy:docker": "docker build -t sonia-ai-companion:latest . && docker run -d --name sonia-ai-companion -p 80:80 sonia-ai-companion:latest",
    "setup": "bash scripts/setup.sh",
    "health": "bash scripts/health-check.sh",
    "monitor": "bash scripts/monitor.sh",
    "backup": "bash scripts/backup.sh",
    "test:load": "bash scripts/load-test.sh"
  },
  "dependencies": {
    "react-dom": "^19.2.0",
    "@google/genai": "^1.24.0",
    "react": "^19.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
